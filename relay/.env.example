# Relay server environment variables
# ─────────────────────────────────────────────────────────────────────────────
# For local dev:   copy to relay/.env  →  make relay
# For Railway:     set these as environment variables in the Railway dashboard
# ─────────────────────────────────────────────────────────────────────────────

# Random secret used to sign JWT tokens.
# Generate a good one: openssl rand -hex 32
JWT_SECRET=change-me-run-openssl-rand-hex-32

# Password for the iOS app login screen.
ADMIN_PASSWORD=your-secure-password

# Pre-shared secret that agents use to authenticate with the relay.
# Must match the 'secret' field in each agent's config.yaml.
AGENT_SECRET=your-agent-secret

# Port to listen on (Railway sets this automatically, no need to change).
PORT=8080
